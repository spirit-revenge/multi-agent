# DeepSeek API Key (required)
# Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Google Programmable Search (required for web search feature)
# Get from: https://programmablesearchengine.google.com/
GOOGLE_CSE_ID=your-google-cse-id
GOOGLE_API_KEY=your-google-api-key

# Flask settings (required for Web UI)
# Generate a random key: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-random-secret-key
WEB_UI_PORT=7860
# Set to "1" to enable Flask debug mode (not recommended for demos)
FLASK_DEBUG=0
